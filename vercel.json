{
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/predict",
      "destination": "/api/predict"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
